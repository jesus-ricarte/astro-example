---
interface Props {
  lang?: string;
  title?: string;
}

const { lang = "en", title = "Site" } = Astro.props;

// Netlify CDN: s-maxage = edge TTL (seconds); SWR serves stale while revalidating.
const CDN_S_MAXAGE_SEC = 300;
const CDN_STALE_WHILE_REVALIDATE_SEC = 86_400;
Astro.response.headers.set(
  "Cache-Control",
  `public, max-age=0, must-revalidate, s-maxage=${CDN_S_MAXAGE_SEC}, stale-while-revalidate=${CDN_STALE_WHILE_REVALIDATE_SEC}`,
);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
