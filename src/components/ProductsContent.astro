---
import { Picture } from "astro:assets";
import { getAllFlotiqProducts } from "../lib/flotiqProducts";
import { getIntlLocale } from "../i18n/config";

interface Props {
  localeCode: string;
  routeId: string;
  heading: string;
}

const { localeCode, routeId, heading } = Astro.props;
const intlLocale = getIntlLocale(localeCode);

if (Astro.url.searchParams.has("sort")) {
  Astro.response.headers.set("Cache-Control", "private, no-store");
}

let products: Awaited<ReturnType<typeof getAllFlotiqProducts>> = [];
let fetchError: string | null = null;

try {
  products = await getAllFlotiqProducts();
} catch (e) {
  fetchError = e instanceof Error ? e.message : "Failed to load products.";
}
---

<section>
  <h1>{heading}</h1>

  {Astro.url.searchParams.has("sort") ? "true" : "false"}

  {
    fetchError ? (
      <p>{fetchError}</p>
    ) : products.length === 0 ? (
      <p>No products returned from Flotiq</p>
    ) : (
      <pre>{JSON.stringify(products, null, 2)}</pre>
    )
  }

  {
    products.map((product) => (
      <div>
        <h2>{product.name}</h2>
        <p>
          {new Intl.NumberFormat(intlLocale, {
            style: "currency",
            currency: "USD",
          }).format(product.price[0].USD)}
        </p>
        <p>
          {new Intl.NumberFormat(intlLocale, {
            style: "currency",
            currency: "ARS",
          }).format(product.price[0].ARS)}
        </p>
        <p>
          {new Intl.NumberFormat(intlLocale, {
            style: "currency",
            currency: "EUR",
          }).format(product.price[0].EUR)}
        </p>
      </div>
    ))
  }

  <Picture
    src="https://i.imgur.com/QkIa5tT.jpeg"
    alt="Description of image"
    width={500}
    height={500}
  />
</section>
