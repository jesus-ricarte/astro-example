---
import { Picture } from "astro:assets";
import { getAllFlotiqProducts } from "../lib/flotiqProducts";

interface Props {
  localeCode: string;
  routeId: string;
  heading: string;
}

const { localeCode, routeId, heading } = Astro.props;

let products: Awaited<ReturnType<typeof getAllFlotiqProducts>> = [];
let fetchError: string | null = null;

try {
  products = await getAllFlotiqProducts();
} catch (e) {
  fetchError =
    e instanceof Error ? e.message : "Failed to load products from Flotiq.";
}
---

<section>
  <h1>{heading}</h1>

  {
    fetchError ? (
      <p>{fetchError}</p>
    ) : products.length === 0 ? (
      <p>No products returned from Flotiq</p>
    ) : (
      <pre>{JSON.stringify(products, null, 2)}</pre>
    )
  }

  {
    products.map((product) => (
      <div>
        <h2>{product.name}</h2>
        <p>
          {new Intl.NumberFormat("es-AR", {
            style: "currency",
            currency: "USD",
          }).format(product.price[0].USD)}
        </p>
        <p>
          {new Intl.NumberFormat("es-AR", {
            style: "currency",
            currency: "ARS",
          }).format(product.price[0].ARS)}
        </p>
        <p>
          {new Intl.NumberFormat("es-ES", {
            style: "currency",
            currency: "EUR",
          }).format(product.price[0].EUR)}
        </p>
        <p>
          {new Intl.NumberFormat("ca-ES", {
            style: "currency",
            currency: "EUR",
          }).format(product.price[0].EUR)}
        </p>
      </div>
    ))
  }

  <!-- <Picture
    src="https://i.imgur.com/QkIa5tT.jpeg"
    alt="Description of image"
    width={500}
    height={500}
  /> -->
</section>

<style>
  .error {
    color: #b00020;
  }
  .product-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
    max-width: 36rem;
  }
  .product-list li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid #e0e0e0;
  }
  .product-list .title {
    font-weight: 600;
  }
  .product-list .meta {
    font-size: 0.85rem;
    color: #666;
  }
  .product-list .id {
    font-family: ui-monospace, monospace;
  }
</style>
