---
import Layout from "../../layouts/Layout.astro";
import ProductsContent from "../../components/ProductsContent.astro";
import { resolvePageRoute } from "../../i18n/config";

const { locale, slug } = Astro.params;
const resolved = locale && slug ? resolvePageRoute(locale, slug) : null;

if (!resolved) {
  return new Response(null, { status: 404 });
}

const pageTitle = resolved.label;
---

<Layout lang={resolved.lang} title={pageTitle}>
  <main>
    <ProductsContent
      localeCode={resolved.code}
      routeId={resolved.routeId}
      heading={pageTitle}
    />
  </main>
</Layout>
