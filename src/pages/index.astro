---
import Layout from "../layouts/Layout.astro";
import { LOCALES, localePathSegment } from "../i18n/config";
---

<Layout>
  <main>
    <ul>
      {
        LOCALES.map((loc) => (
          <li>
            <a href={`/${localePathSegment(loc.code)}/`}>{loc.label}</a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
